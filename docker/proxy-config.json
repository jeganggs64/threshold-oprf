  "nodes": [
    {
      "node_id": 1,
      "endpoint": "https://node-1:3001",
      "verification_share": "PLACEHOLDER"
    },
    {
      "node_id": 2,
      "endpoint": "https://node-2:3001",
      "verification_share": "PLACEHOLDER"
    },
    {
      "node_id": 3,
      "endpoint": "https://node-3:3001",
      "verification_share": "PLACEHOLDER"
    }
  ]
