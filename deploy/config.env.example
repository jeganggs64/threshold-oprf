# =============================================================================
# Deployment configuration for threshold OPRF system (all-AWS).
#
# Prerequisites:
#   - 3 AWS TEE VMs (AMD SEV-SNP) in different regions
#   - IAM instance profiles attached to each VM
#   - SSH access to all 3 VMs
#   - aws CLI authenticated locally
#   - jq, openssl, curl installed locally
#
# Auto-config:
#   Run `./deploy.sh auto-config` after filling in the manual fields.
# =============================================================================

# ─── AWS Account ────────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=                       # [auto] from aws sts get-caller-identity
ECR_REGION=eu-west-2                  # [manual]

# ─── Provisioning ──────────────────────────────────────────────────────────
INSTANCE_TYPE=c6a.large               # [manual] VM instance type for nodes
IAM_INSTANCE_PROFILE=                 # [manual] IAM instance profile name for S3 access

# ─── Node image (built by CI, pulled from ghcr.io) ─────────────────────────
# NODE_IMAGE=ghcr.io/<your-username>/toprf-node:latest  # [manual] override if needed

# ─── Node 1 ────────────────────────────────────────────────────────────────
NODE1_REGION=ap-southeast-1           # [manual]
NODE1_KEY_NAME=                       # [manual] AWS key pair name (for provisioning)
NODE1_SSH_KEY=                        # [manual] path to SSH private key (.pem)
NODE1_IP=                             # [auto] from aws ec2 describe-instances
NODE1_PRIVATE_IP=                     # [auto] from aws ec2 describe-instances
NODE1_SG_ID=                          # [auto] from EC2 instance security groups
NODE1_VPC_ID=                         # [auto] from EC2 instance
NODE1_S3_BUCKET=                      # [manual] e.g. my-sealed-node1
NODE1_SNP_PROVIDER=raw                # [manual]

# ─── Node 2 ────────────────────────────────────────────────────────────────
NODE2_REGION=us-east-1                # [manual]
NODE2_KEY_NAME=                       # [manual] AWS key pair name (for provisioning)
NODE2_SSH_KEY=                        # [manual] path to SSH private key (.pem)
NODE2_IP=                             # [auto] from aws ec2 describe-instances
NODE2_PRIVATE_IP=                     # [auto] from aws ec2 describe-instances
NODE2_SG_ID=                          # [auto] from EC2 instance security groups
NODE2_VPC_ID=                         # [auto] from EC2 instance
NODE2_S3_BUCKET=                      # [manual] e.g. my-sealed-node2
NODE2_SNP_PROVIDER=raw                # [manual]

# ─── Node 3 ────────────────────────────────────────────────────────────────
NODE3_REGION=eu-west-1                # [manual]
NODE3_KEY_NAME=                       # [manual] AWS key pair name (for provisioning)
NODE3_SSH_KEY=                        # [manual] path to SSH private key (.pem)
NODE3_IP=                             # [auto] from aws ec2 describe-instances
NODE3_PRIVATE_IP=                     # [auto] from aws ec2 describe-instances
NODE3_SG_ID=                          # [auto] from EC2 instance security groups
NODE3_VPC_ID=                         # [auto] from EC2 instance
NODE3_S3_BUCKET=                      # [manual] e.g. my-sealed-node3
NODE3_SNP_PROVIDER=raw                # [manual]

# ─── Node shares ───────────────────────────────────────────────────────────
NODE_SHARES_DIR=../ceremony/node-shares  # [manual]

# ─── Proxy (ECS) ───────────────────────────────────────────────────────────
PROXY_REGION=eu-west-2                # [manual] must match ECR_REGION
PROXY_VPC_CIDR=10.0.0.0/16           # [auto] from ecs-state.env
PROXY_IP=                             # [auto] from ecs-state.env (NAT Gateway EIP)
DOMAIN=                               # [manual] e.g. api.example.com

# ─── Redis (ElastiCache) ───────────────────────────────────────────────────
REDIS_CLUSTER_ID=                     # [manual]
