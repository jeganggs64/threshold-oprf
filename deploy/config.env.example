# =============================================================================
# Deployment configuration — copy to config.env and fill in your values.
#
# Prerequisites (create these BEFORE running deploy.sh):
#   - 3 TEE VMs (GCP, Azure, AWS) with AMD SEV-SNP
#   - IAM roles / instance profiles / managed identities attached to each VM
#   - SSH access to all 3 VMs
#   - gcloud, az, aws CLIs authenticated on your local machine
#   - jq, openssl, curl installed locally
#
# Auto-config:
#   Run `./deploy.sh auto-config` after filling in the manual fields below.
#   Fields marked [auto] will be fetched from cloud providers automatically.
#   Fields marked [manual] must be filled in by you.
# =============================================================================

# ─── AWS (for storage + ECS) ──────────────────────────────────────────────────
AWS_ACCOUNT_ID=                       # [auto] from aws sts get-caller-identity
ECR_REGION=eu-west-2                  # [manual]

# ─── Node image (built by CI, pulled from ghcr.io) ────────────────────────────
# NODE_IMAGE=ghcr.io/<your-username>/toprf-node:latest  # [manual] override if needed

# ─── Node 1: GCP ─────────────────────────────────────────────────────────────
GCP_PROJECT=                          # [manual]
GCP_VM_NAME=toprf-node-1              # [manual]
GCP_ZONE=asia-southeast1-b            # [manual]
NODE1_IP=                             # [auto] from gcloud compute instances describe
NODE1_SNP_PROVIDER=gcp                # [manual]
GCP_BUCKET=                           # [manual] e.g. my-sealed-node1

# ─── Node 2: Azure ───────────────────────────────────────────────────────────
AZURE_RG=                             # [manual]
AZURE_VM_NAME=toprf-node-2            # [manual]
AZURE_USER=azureuser                  # [manual]
NODE2_IP=                             # [auto] from az vm show
NODE2_SNP_PROVIDER=raw                # [manual]
AZURE_STORAGE_ACCOUNT=                # [manual] e.g. mysealednode2
AZURE_STORAGE_CONTAINER=sealed-blobs  # [manual]

# ─── Node 3: AWS ─────────────────────────────────────────────────────────────
AWS_NODE_REGION=eu-west-1             # [manual]
AWS_SSH_KEY=                          # [manual] path to SSH private key (.pem)
AWS_SG_ID=                            # [auto] from EC2 instance security groups
NODE3_IP=                             # [auto] from aws ec2 describe-instances
NODE3_SNP_PROVIDER=raw                # [manual]
AWS_S3_BUCKET=                        # [manual] e.g. my-sealed-node3

# ─── Node shares ────────────────────────────────────────────────────────────
# Output directory from `toprf-keygen node-shares`. Must contain:
#   public-config.json
#   node-{1,2,3}-share.json
NODE_SHARES_DIR=./node-shares          # [manual]

# ─── Proxy host ──────────────────────────────────────────────────────────────
# Public IP of the host running Express + Rust proxy (NAT Gateway EIP if ECS).
# Used for firewall rules (allow proxy → nodes on port 3001).
PROXY_IP=                             # [auto] from ecs-state.env (NAT Gateway EIP)
