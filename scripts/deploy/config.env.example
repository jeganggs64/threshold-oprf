# =============================================================================
# Deployment configuration — copy to config.env and fill in your values.
#
# Prerequisites (create these BEFORE running deploy.sh):
#   - 3 TEE VMs (GCP, Azure, AWS) with AMD SEV-SNP
#   - IAM roles / instance profiles / managed identities attached to each VM
#   - SSH access to all 3 VMs
#   - gcloud, az, aws CLIs authenticated on your local machine
#   - jq, openssl, curl installed locally
# =============================================================================

# ─── AWS (for storage + ECS) ──────────────────────────────────────────────────
AWS_ACCOUNT_ID=
ECR_REGION=eu-west-2

# ─── Git repo (cloned on each VM to build Docker images natively) ─────────────
# REPO_URL=https://github.com/<your-org>/threshold-oprf.git

# ─── Node 1: GCP ─────────────────────────────────────────────────────────────
GCP_PROJECT=
GCP_VM_NAME=toprf-node-1
GCP_ZONE=asia-southeast1-b
NODE1_IP=                         # Fill after VM creation
NODE1_SNP_PROVIDER=gcp
GCP_BUCKET=                       # e.g. my-sealed-node1

# ─── Node 2: Azure ───────────────────────────────────────────────────────────
AZURE_RG=
AZURE_VM_NAME=toprf-node-2
AZURE_USER=azureuser
NODE2_IP=                         # Fill after VM creation
NODE2_SNP_PROVIDER=raw
AZURE_STORAGE_ACCOUNT=            # e.g. mysealednode2
AZURE_STORAGE_CONTAINER=sealed-blobs

# ─── Node 3: AWS ─────────────────────────────────────────────────────────────
AWS_NODE_REGION=eu-west-1
AWS_SSH_KEY=                      # Path to SSH private key (.pem)
AWS_SG_ID=                        # Security group ID (sg-xxxx)
NODE3_IP=                         # Fill after VM creation
NODE3_SNP_PROVIDER=raw
AWS_S3_BUCKET=                    # e.g. my-sealed-node3

# ─── Key ceremony ────────────────────────────────────────────────────────────
# Output directory from `toprf-keygen init`. Must contain:
#   public-config.json
#   node-shares/node-{1,2,3}-share.json
CEREMONY_DIR=./ceremony

# ─── Proxy host ──────────────────────────────────────────────────────────────
# Public IP of the host running Express + Rust proxy (NAT Gateway EIP if ECS).
# Used for firewall rules (allow proxy → nodes on port 3001).
PROXY_IP=
