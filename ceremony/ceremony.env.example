# AWS credentials for the ceremony.
# Use any IAM user with admin access.
# This file will be shredded at the end of the ceremony.

AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=eu-west-1

# Identity for local OPRF verification (step 11).
# Use your own national ID to verify the server produces the same
# ruonId as the local ceremony. Must match exactly what the mobile
# app passes to hashToCurve — the full country name, not ISO code.
NATIONALITY=Singapore
NATIONAL_ID=S1234567A
