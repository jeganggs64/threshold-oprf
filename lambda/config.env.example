# OPRF Lambda deployment config
# Copy to config.env and fill in values
ACCOUNT_ID=
API_ID=
LAMBDA_PREFIX=ruonid
REGION=eu-west-1
ROLE_ARN=

# Apple App Attest
APPLE_APP_ID=
APPLE_TEAM_ID=

# VPC config for evaluate Lambda (needs internal NLB access)
VPC_SUBNETS=
VPC_SG=

# DynamoDB table names
NONCES_TABLE=ruonid-nonces
DEVICE_KEYS_TABLE=ruonid-device-keys

# Coordinator NLB URL
NLB_URL=
